generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * -------------------------------- ENUMS --------------------------------
 */

enum USER_ROLE {
  hr
  admin
  inventory_manager
  user
  auditor
}

enum REQUEST_STATUS {
  pending
  sent
}

enum TRANSACTION_TYPE {
  stock_in
  dispensed
  wastage
  adjustment
}

enum ALERT_TYPE {
  expiry_warning
  expired
  low_stock
  out_of_stock
}

enum ALERT_STATUS {
  pending
  read
  resolved
}

enum MEDICINE_AGE_GROUP {
  infant
  pediatric
  adult
  geriatric
  all_ages
}

enum PAYMENT_METHOD {
  cash
  mpesa
  card
  insurance
}

/**
 * -------------------------------- MODELS --------------------------------
 */

model User {
  id                String    @id
  name              String
  email             String
  emailVerified     Boolean
  image             String?
  role              String    @default("user")
  employeeId        String?
  banned            Boolean   @default(false)
  banReason         String?
  banExpires        DateTime?
  emailAlertEnabled Boolean?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  phone             String

  sessions             Session[]
  accounts             Account[]
  transactions         Transactions[]
  payments             Payment[]
  sentInvitations      Invitation[]        @relation("SentInvitations")
  requestedInvitations InvitationRequest[] @relation("RequestedInvitations")
  alerts               Alerts[]

  @@unique([email])
  @@unique([phone])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  impersonatedBy String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model InvitationRequest {
  id String @id @default(cuid())

  name       String
  email      String    @unique
  role       USER_ROLE @default(user)
  employeeId String

  requestedById String
  requestedBy   User   @relation("RequestedInvitations", fields: [requestedById], references: [id], onDelete: Cascade)

  status REQUEST_STATUS @default(pending)
  phone  String         @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitation Invitation?

  @@index([status])
  @@index([requestedById])
  @@map("invitation_request")
}

model Invitation {
  id String @id @default(cuid())

  requestId String            @unique
  request   InvitationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  token String @unique

  invitedById String
  invitedBy   User   @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?

  @@index([token])
  @@map("invitation")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  medicines Medicines[]

  @@map("categories")
}

model Medicines {
  id           String @id @default(cuid())
  name         String
  unit         String
  reorderlevel Int

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  ageGroup MEDICINE_AGE_GROUP @default(all_ages)
  isActive Boolean            @default(true)

  dosage    String @default("2 times daily")
  unitPrice Int    @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt    DateTime?
  manufacturer String?

  stockEntries StockEntries[]
  alerts       Alerts[]

  @@index([name, isActive, categoryId])
  @@map("medicines")
}

model StockEntries {
  id          String @id @default(cuid())
  batchNumber String @unique

  medicineId String
  medicine   Medicines @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  quantity         Int
  initialtQuantity Int
  expiryDate       DateTime
  purchaseDate     DateTime
  purchasePrice    Int
  supplier         String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions Transactions[]
  alerts       Alerts[]

  @@index([batchNumber, medicineId, expiryDate])
  @@map("stock_entries")
}

model Transactions {
  id String @id @default(cuid())

  stockEntriesId String
  stockEntry     StockEntries @relation(fields: [stockEntriesId], references: [id], onDelete: Cascade)

  type     TRANSACTION_TYPE @default(dispensed)
  quantity Int
  reason   String

  patientId     String?
  patientRecord Patient? @relation(fields: [patientId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  notes String?

  createdAt DateTime @default(now())

  payment Payment?

  @@index([stockEntriesId, type])
  @@map("transactions")
}

model Alerts {
  id   String     @id @default(cuid())
  type ALERT_TYPE @default(low_stock)

  stockEntriesId String
  stockEntry     StockEntries @relation(fields: [stockEntriesId], references: [id], onDelete: Cascade)

  medicinesId String
  medicines   Medicines @relation(fields: [medicinesId], references: [id], onDelete: Cascade)

  message String
  status  ALERT_STATUS @default(pending)

  resolvedById String?
  resolvedBy   User?   @relation(fields: [resolvedById], references: [id])

  createdAt  DateTime  @default(now())
  readAt     DateTime?
  resolvedAt DateTime?

  @@index([stockEntriesId, medicinesId])
  @@map("alerts")
}

model Settings {
  id                     String   @id @default(cuid())
  facilityName           String
  facilityAddress        String
  expiryWarnDays         Int
  criticalExpiryWarnDays Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("settings")
}

model Payment {
  id String @id @default(cuid())

  transactionId String       @unique
  transaction   Transactions @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  amount      Int
  paymentCode String         @unique
  method      PAYMENT_METHOD

  processedById String
  processedBy   User   @relation(fields: [processedById], references: [id])

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([paymentCode])
  @@map("payments")
}

model Patient {
  id       String             @id @default(cuid())
  name     String
  phone    String             @unique
  ageGroup MEDICINE_AGE_GROUP

  createdAt DateTime @default(now())

  transactions Transactions[]

  @@index([name, phone])
  @@map("patients")
}
